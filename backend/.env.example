# =============================================================================
# EVENT PASSPORT PWA — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values before running the app.
# Never commit your .env file to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# 🎫 EVENT IDENTITY
# These values appear in the UI and emails. Customize for your event.
# -----------------------------------------------------------------------------

EVENT_NAME="Your Event Name"
EVENT_EDITION="2026"
EVENT_CITY="Your City"
EVENT_DATE="Jun 26-27, 2026"
EVENT_VENUE="Your Venue"
EVENT_URL="https://yourevent.example.com"


# -----------------------------------------------------------------------------
# 🎟️ STAMP & PRIZE CONFIGURATION
# -----------------------------------------------------------------------------

# Number of stamps an attendee needs to collect to qualify for prizes
STAMPS_REQUIRED=5

# Maximum number of stamps one attendee can collect (set to number of sponsors)
MAX_STAMPS=10


# -----------------------------------------------------------------------------
# 🗄️ DATABASE
# -----------------------------------------------------------------------------

# Local development (Docker — see infra/docker-compose.yml)
DATABASE_URL="postgresql://<user>:<password>@localhost:5432/<database>"

# Production example (Railway)
# DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<database>?sslmode=require"


# -----------------------------------------------------------------------------
# 🔐 AUTHENTICATION
# -----------------------------------------------------------------------------

# JWT secret — generate a strong random value for production
# Use: openssl rand -hex 64
JWT_SECRET="change-me-in-production"

# Token expiry for attendee sessions
JWT_EXPIRES_IN="24h"

# Token expiry for staff sessions
STAFF_JWT_EXPIRES_IN="8h"


# -----------------------------------------------------------------------------
# 🌐 APP URLS
# -----------------------------------------------------------------------------

# Backend port
PORT=3000

# Frontend URL — used for CORS allowlist
FRONTEND_URL="http://localhost:5173"

# Production example
# FRONTEND_URL="https://your-app.up.railway.app"


# -----------------------------------------------------------------------------
# 📧 EMAIL (optional)
# Only needed if using email-based session recovery
# -----------------------------------------------------------------------------

# RESEND_API_KEY="<your-resend-api-key>"
# EMAIL_FROM="passport@yourevent.example.com"


# -----------------------------------------------------------------------------
# 🛡️ SECURITY
# -----------------------------------------------------------------------------

# Rate limiting — requests per minute per IP (default: 60)
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=60

# CORS — additional allowed origins (comma-separated, optional)
# CORS_EXTRA_ORIGINS="https://yourevent.example.com,https://www.yourevent.example.com"


# -----------------------------------------------------------------------------
# 🚀 DEPLOY (Railway / Docker)
# Set automatically by Railway — only needed for local override
# -----------------------------------------------------------------------------

# NODE_ENV="production"
# RAILWAY_STATIC_URL="https://your-app.up.railway.app"
