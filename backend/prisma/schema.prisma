// Passport BSides Porto — Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id         String     @id @default(uuid())
  name       String
  date       DateTime
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  sponsors   Sponsor[]
  attendees  Attendee[]
}

model Sponsor {
  id          String   @id @default(uuid())
  name        String
  boothNumber String?
  logoUrl     String?
  qrCode      String   @unique @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  stamps      Stamp[]
  createdAt   DateTime @default(now())
}

model Attendee {
  id           String   @id @default(uuid())
  name         String
  email        String
  company      String?
  rgpdConsent  Boolean  @default(false)
  token        String   @unique @default(uuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id])
  stamps       Stamp[]
  createdAt    DateTime @default(now())

  @@unique([email, eventId])
}

model Stamp {
  id          String   @id @default(uuid())
  attendeeId  String
  sponsorId   String
  scannedAt   DateTime @default(now())
  attendee    Attendee @relation(fields: [attendeeId], references: [id])
  sponsor     Sponsor  @relation(fields: [sponsorId], references: [id])

  @@unique([attendeeId, sponsorId])
}

model Staff {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model RecoveryCode {
  id          String   @id @default(uuid())
  email       String
  eventId     String
  code        String
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([email, eventId])
}