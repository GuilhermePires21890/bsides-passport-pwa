### QA4 — SECURITY TEST
### Event Passport PWA — Template
### Tests XSS, SQL injection, auth bypass, and rate limiting.
### Run QA1 first to confirm the API is reachable.

# ─────────────────────────────────────────
# CONFIGURATION
# ─────────────────────────────────────────
@baseUrl = http://localhost:3000/api
@eventId = <your-event-id>

# Production example:
# @baseUrl = https://your-app.up.railway.app/api


# ─────────────────────────────────────────
# SEC01 — XSS in name field
# Expected: 400 or sanitized name (no script tag)
# ─────────────────────────────────────────
### SEC01
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "<script>alert('xss')</script>",
  "email": "sec01@example.com",
  "rgpdConsent": true,
  "eventId": "{{eventId}}"
}

###

# ─────────────────────────────────────────
# SEC02 — XSS in company field
# Expected: 400 or sanitized company value
# ─────────────────────────────────────────
### SEC02
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Security Test",
  "email": "sec02@example.com",
  "company": "<img src=x onerror=alert(1)>",
  "rgpdConsent": true,
  "eventId": "{{eventId}}"
}

###

# ─────────────────────────────────────────
# SEC03 — SQL injection in email
# Expected: 400
# ─────────────────────────────────────────
### SEC03
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Security Test",
  "email": "' OR 1=1--@test.com",
  "rgpdConsent": true,
  "eventId": "{{eventId}}"
}

###

# ─────────────────────────────────────────
# SEC04 — Access admin without JWT
# Expected: 401
# ─────────────────────────────────────────
### SEC04
GET {{baseUrl}}/admin/dashboard?eventId={{eventId}}

###

# ─────────────────────────────────────────
# SEC05 — Tampered JWT token
# Expected: 401
# ─────────────────────────────────────────
### SEC05
GET {{baseUrl}}/admin/dashboard?eventId={{eventId}}
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJmYWtlLWlkLTEyMyIsImVtYWlsIjoiYXR0YWNrZXJAaGFjay5jb20iLCJyb2xlIjoic3RhZmYiLCJpYXQiOjE3MDAwMDAwMDAsImV4cCI6OTk5OTk5OTk5OX0.fakesignature

###

# ─────────────────────────────────────────
# SEC06 — Rate limit on registration (run 6x rapidly)
# Expected: 429 on the 6th request
# TIP: use REST Client "Send All Requests" or run in rapid succession
# ─────────────────────────────────────────
### SEC06
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Rate Test",
  "email": "sec06.ratelimit@example.com",
  "rgpdConsent": true,
  "eventId": "{{eventId}}"
}

###

# ─────────────────────────────────────────
# SEC07 — Rate limit on staff login (run 6x rapidly)
# Expected: 429 on the 6th request
# ─────────────────────────────────────────
### SEC07
POST {{baseUrl}}/auth/staff/login
Content-Type: application/json

{
  "email": "attacker@hack.com",
  "password": "wrongpassword"
}

###

# ─────────────────────────────────────────
# SEC08 — Create staff without JWT
# Expected: 401
# ─────────────────────────────────────────
### SEC08
POST {{baseUrl}}/auth/staff/create
Content-Type: application/json

{
  "name": "Fake Staff",
  "email": "fakestaff@hack.com",
  "password": "hacked123"
}
