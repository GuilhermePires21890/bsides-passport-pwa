### QA3 — BOUNDARY TEST
### Event Passport PWA — Template
### Tests input validation and edge cases.
### Run QA1 first to confirm the API is reachable.

# ─────────────────────────────────────────
# CONFIGURATION
# ─────────────────────────────────────────
@baseUrl = http://localhost:3000/api
@eventId = <your-event-id>

# A valid attendee token (from QA2/F01) — needed for B07 and B08
@attendeeToken = <paste-token-here>

# A valid sponsor QR code (from admin panel) — needed for B08
@qrCodeSponsor = <sponsor-qr-code-uuid>

# Production example:
# @baseUrl = https://your-app.up.railway.app/api


# ─────────────────────────────────────────
# B01 — Register without name
# Expected: 400
# ─────────────────────────────────────────
### B01
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "",
  "email": "b01@example.com",
  "rgpdConsent": true,
  "eventId": "{{eventId}}"
}

###

# ─────────────────────────────────────────
# B02 — Register with name > 100 characters
# Expected: 400
# ─────────────────────────────────────────
### B02
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
  "email": "b02@example.com",
  "rgpdConsent": true,
  "eventId": "{{eventId}}"
}

###

# ─────────────────────────────────────────
# B03 — Register with invalid email
# Expected: 400
# ─────────────────────────────────────────
### B03
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Boundary Test",
  "email": "notanemail",
  "rgpdConsent": true,
  "eventId": "{{eventId}}"
}

###

# ─────────────────────────────────────────
# B04 — Register without eventId
# Expected: 400
# ─────────────────────────────────────────
### B04
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Boundary Test",
  "email": "b04@example.com",
  "rgpdConsent": true,
  "eventId": ""
}

###

# ─────────────────────────────────────────
# B05 — Register without RGPD consent
# Expected: 400
# ─────────────────────────────────────────
### B05
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Boundary Test",
  "email": "b05@example.com",
  "rgpdConsent": false,
  "eventId": "{{eventId}}"
}

###

# ─────────────────────────────────────────
# B06 — Resume with non-existent token
# Expected: 401
# ─────────────────────────────────────────
### B06
GET {{baseUrl}}/auth/resume?token=token-that-does-not-exist-123456

###

# ─────────────────────────────────────────
# B07 — Scan with invalid QR code
# Expected: 404
# ─────────────────────────────────────────
### B07
POST {{baseUrl}}/stamps/scan
Content-Type: application/json

{
  "token": "{{attendeeToken}}",
  "qrCode": "qr-code-that-does-not-exist-999"
}

###

# ─────────────────────────────────────────
# B08 — Duplicate scan (same token + same QR)
# Expected: 409
# NOTE: run F04 from QA2 first, then run this with the same token + QR
# ─────────────────────────────────────────
### B08
POST {{baseUrl}}/stamps/scan
Content-Type: application/json

{
  "token": "{{attendeeToken}}",
  "qrCode": "{{qrCodeSponsor}}"
}
