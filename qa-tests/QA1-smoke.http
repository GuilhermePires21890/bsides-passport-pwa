@baseUrl = https://passport-bsides-porto-production.up.railway.app/api
@eventId = YOUR_EVENT_ID

# ─────────────────────────────────────────
# S01 — API está online
# Esperado: 200 + evento activo
# ─────────────────────────────────────────
### S01
GET {{baseUrl}}/events/active

###

# ─────────────────────────────────────────
# S02 — Sponsors carregam
# Esperado: 200 + lista de sponsors
# ─────────────────────────────────────────
### S02
GET {{baseUrl}}/sponsors?eventId={{eventId}}

###

# ─────────────────────────────────────────
# S03 — Admin login responde
# Esperado: 401 (credenciais erradas intencionais — confirmar que endpoint responde)
# ─────────────────────────────────────────
### S03
POST {{baseUrl}}/auth/staff/login
Content-Type: application/json

